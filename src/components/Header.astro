---
const navLinks = [
  { href: '/', label: 'トップ' },
  { href: '/news', label: 'ニュース' },
  { href: '/organizations', label: '団体リスト' },
  { href: '/subsidies', label: '補助金・助成金' },
  { href: '/contact', label: 'お問い合わせ' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- ロゴ -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center flex-shrink-0">
          <span class="text-white font-bold text-sm">火</span>
        </div>
        <span class="font-bold text-lg text-gray-900 group-hover:text-primary-600 transition-colors">
          火の国未来創造ネット
        </span>
      </a>

      <!-- デスクトップナビ -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 rounded-md text-sm font-medium transition-colors',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-primary-600 bg-primary-50'
                : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100',
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- モバイルメニューボタン -->
      <button
        id="menu-btn"
        class="md:hidden p-2 rounded-md text-gray-600 hover:bg-gray-100"
        aria-label="メニューを開く"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- モバイルメニュー -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
    <nav class="px-4 py-3 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-2 rounded-md text-sm font-medium transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-primary-600 bg-primary-50'
              : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
