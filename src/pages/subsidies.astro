---
import Layout from '../layouts/Layout.astro';
import { client } from '../lib/microcms';
import type { Subsidy } from '../lib/microcms';

const isDev = import.meta.env.DEV && !import.meta.env.MICROCMS_API_KEY;

let subsidies: Subsidy[] = [];

if (!isDev) {
  const res = await client.getList<Subsidy>({
    endpoint: 'subsidies',
    queries: { limit: 100 },
  });
  subsidies = res.contents;
} else {
  subsidies = [
    {
      id: '1', title: '令和7年度 地域活動支援補助金',
      summary: '地域の課題解決に向けた市民活動・NPO活動を支援します。',
      target: 'NPO法人・任意団体', amount: '上限50万円',
      deadline: '2026-05-31', category: '市民活動',
      url: 'https://example.com',
    },
    {
      id: '2', title: '子ども・若者支援活動助成金',
      summary: '子どもや若者の健全育成・居場所づくりに取り組む団体を支援します。',
      target: 'NPO法人・ボランティア団体', amount: '上限100万円',
      deadline: '2026-06-15', category: '子ども支援',
    },
    {
      id: '3', title: '環境保全活動推進費補助金',
      summary: '地域の環境保全・生物多様性の保護に係る活動を支援します。',
      target: '地域団体・NPO', amount: '上限30万円',
      deadline: '2026-04-30', category: '環境',
    },
    {
      id: '4', title: 'くまもと地域共生社会推進助成',
      summary: '高齢者・障がい者・外国人など多様な人が共に暮らせる地域づくりを支援します。',
      target: 'NPO法人・社会福祉法人', amount: '上限200万円',
      deadline: '2026-07-31', category: '福祉・共生',
    },
    {
      id: '5', title: '農山漁村活性化プロジェクト支援交付金',
      summary: '農山漁村の活性化・移住定住促進に向けた取り組みを支援します。',
      target: '地方公共団体・農業者団体', amount: '定額補助',
      deadline: '2026-05-10', category: '農業・地域振興',
    },
  ];
}

function formatDeadline(dateStr?: string) {
  if (!dateStr) return '随時';
  const d = new Date(dateStr);
  const today = new Date();
  const diff = Math.ceil((d.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
  const label = d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
  if (diff < 0) return `締切済み (${label})`;
  if (diff <= 14) return `⚠️ 締切間近 ${label} (残り${diff}日)`;
  return label;
}

function isExpired(dateStr?: string) {
  if (!dateStr) return false;
  return new Date(dateStr) < new Date();
}

const categoryColors: Record<string, string> = {
  '市民活動': 'bg-blue-100 text-blue-700',
  '子ども支援': 'bg-pink-100 text-pink-700',
  '子ども・青少年': 'bg-pink-100 text-pink-700',
  '環境': 'bg-teal-100 text-teal-700',
  '福祉・共生': 'bg-purple-100 text-purple-700',
  '農業・地域振興': 'bg-amber-100 text-amber-700',
  '農業・産業': 'bg-amber-100 text-amber-700',
  '文化・国際交流': 'bg-indigo-100 text-indigo-700',
  'コミュニティ活動': 'bg-emerald-100 text-emerald-700',
  'まちづくり': 'bg-sky-100 text-sky-700',
  '防災・安全': 'bg-red-100 text-red-700',
  '移住・定住': 'bg-green-100 text-green-700',
  '人材・起業': 'bg-orange-100 text-orange-700',
  '多文化共生': 'bg-violet-100 text-violet-700',
};

// カテゴリ一覧（重複除去）
const allCategories = ['すべて', ...new Set(subsidies.map((s) => s.category).filter(Boolean))];
---

<Layout title="補助金・助成金情報" description="熊本県内の地域団体・NPO向けの補助金・助成金情報を随時更新。市民活動・環境・福祉・農業など各分野の支援制度をまとめています。">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <h1 class="section-title">補助金・助成金情報</h1>
      <p class="section-subtitle">地域活動の資金調達に役立つ情報をまとめています</p>
    </div>

    <!-- PDFダウンロードバナー -->
    <div class="bg-primary-50 border border-primary-200 rounded-xl p-5 mb-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="flex-1">
        <a href="https://www.pref.kumamoto.jp/site/kumamoto-chisou/177924.html" target="_blank" rel="noopener noreferrer" class="font-bold text-primary-800 hover:underline mb-1 inline-block">📄 令和7年度 地方創生財源ハンドブック</a>
        <p class="text-sm text-primary-700">熊本県総務部が作成した補助金・交付金359事業を収録したハンドブック（PDF・8MB）。全情報を網羅的に確認できます。</p>
      </div>
      <a
        href="/R7地方創生財源ハンドブック.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors text-sm"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        PDFをダウンロード
      </a>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 text-sm text-amber-800">
      ※ 情報は随時更新していますが、最新の申請要件・締切日は必ず各公式サイトでご確認ください。
    </div>

    <!-- カテゴリフィルター -->
    <div class="mb-6 flex flex-wrap gap-2" id="cat-btns">
      {allCategories.map((cat) => (
        <button
          data-category={cat}
          class:list={[
            'px-3 py-1.5 rounded-full text-sm font-medium border transition-colors sub-cat-btn',
            cat === 'すべて'
              ? 'bg-primary-600 text-white border-primary-600'
              : 'bg-white text-gray-600 border-gray-300 hover:border-primary-400',
          ]}
        >
          {cat}
        </button>
      ))}
    </div>

    <div class="space-y-5" id="subsidy-list">
      {subsidies.map((sub) => (
        <div class:list={['card p-6 subsidy-card', isExpired(sub.deadline) ? 'opacity-60' : '']} data-category={sub.category}>
          <div class="flex flex-wrap items-center gap-2 mb-3">
            <span class:list={['badge', categoryColors[sub.category] ?? 'bg-gray-100 text-gray-600']}>
              {sub.category}
            </span>
            {isExpired(sub.deadline) && (
              <span class="badge bg-gray-100 text-gray-500">締切済み</span>
            )}
          </div>

          <h2 class="font-bold text-gray-900 text-lg mb-2">{sub.title}</h2>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">{sub.summary}</p>

          <dl class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
            <div class="bg-gray-50 rounded-lg p-3">
              <dt class="text-xs text-gray-400 mb-1">対象</dt>
              <dd class="font-medium text-gray-700">{sub.target}</dd>
            </div>
            {sub.amount && (
              <div class="bg-gray-50 rounded-lg p-3">
                <dt class="text-xs text-gray-400 mb-1">補助額</dt>
                <dd class="font-medium text-gray-700">{sub.amount}</dd>
              </div>
            )}
            {sub.deadline && (
              <div class="bg-gray-50 rounded-lg p-3">
                <dt class="text-xs text-gray-400 mb-1">申請締切</dt>
                <dd class="font-medium text-gray-700">{formatDeadline(sub.deadline)}</dd>
              </div>
            )}
          </dl>

          {sub.url && (
            <div class="mt-4">
              <a
                href={sub.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-outline text-sm py-2"
              >
                詳細・申請はこちら →
              </a>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</Layout>

<script>
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.sub-cat-btn');
  const cards = document.querySelectorAll<HTMLElement>('.subsidy-card');

  catBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.category ?? 'すべて';
      catBtns.forEach((b) => {
        b.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
        b.classList.add('bg-white', 'text-gray-600', 'border-gray-300');
      });
      btn.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
      btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-300');

      cards.forEach((card) => {
        const match = selected === 'すべて' || card.dataset.category === selected;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>
