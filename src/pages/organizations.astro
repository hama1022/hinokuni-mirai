---
import Layout from '../layouts/Layout.astro';
import { client } from '../lib/microcms';
import type { Organization } from '../lib/microcms';

const isDev = import.meta.env.DEV && !import.meta.env.MICROCMS_API_KEY;

let orgs: Organization[] = [];

if (!isDev) {
  const res = await client.getList<Organization>({
    endpoint: 'organizations',
    queries: { limit: 100 },
  });
  orgs = res.contents;
} else {
  orgs = [
    { id: '1', name: '熊本まちづくりの会', description: '地域の課題解決に取り組む市民団体です。年間を通じてワークショップや勉強会を開催しています。', category: ['観光交流', '文化'], area: '熊本市', url: 'https://example.com' },
    { id: '2', name: 'くまもと子ども食堂ネット', description: '子どもたちの食と居場所を支援するネットワークです。県内20か所以上の子ども食堂と連携しています。', category: ['福祉健康', '教育'], area: '県内全域' },
    { id: '3', name: 'ひごの里山保全隊', description: '里山の環境保全活動を行っています。竹林整備・農地保全・生物多様性の保護に取り組んでいます。', category: ['環境', '農林業'], area: '阿蘇・山鹿' },
    { id: '4', name: '菊陽高齢者サポート', description: '高齢者の生活を地域で支えます。見守り・配食・移動支援などのサービスを提供しています。', category: ['福祉健康'], area: '菊陽町' },
    { id: '5', name: '天草観光振興協議会', description: '天草の魅力を国内外に発信しています。体験型観光の開発・インバウンド対応に注力しています。', category: ['観光交流'], area: '天草市' },
    { id: '6', name: 'くまもと防災ボランティア', description: '災害時の支援活動に備えています。定期的な訓練と地域コミュニティとの連携を大切にしています。', category: ['防災'], area: '県内全域' },
    { id: '7', name: '熊本外国人支援センター', description: '在住外国人の生活相談・日本語教育・多文化共生の推進に取り組んでいます。', category: ['文化', '移住'], area: '熊本市' },
    { id: '8', name: '球磨川流域自然再生協議会', description: '球磨川流域の自然環境再生と持続可能な地域づくりを推進しています。', category: ['環境'], area: '人吉・球磨' },
  ];
}

// カテゴリ一覧（重複除去・配列をフラット化）
const categories = ['すべて', ...new Set(orgs.flatMap((o) => o.category ?? []))];

const categoryColors: Record<string, string> = {
  '観光交流': 'bg-amber-100 text-amber-700',
  '産業': 'bg-blue-100 text-blue-700',
  '農林業': 'bg-green-100 text-green-700',
  '環境': 'bg-teal-100 text-teal-700',
  '福祉健康': 'bg-purple-100 text-purple-700',
  '教育': 'bg-indigo-100 text-indigo-700',
  '文化': 'bg-pink-100 text-pink-700',
  '移住': 'bg-emerald-100 text-emerald-700',
  '防災': 'bg-red-100 text-red-700',
  '情報発信': 'bg-cyan-100 text-cyan-700',
};
---

<Layout title="団体リスト" description="熊本県内で活動する地域団体・NPOのリスト">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <h1 class="section-title">団体リスト</h1>
      <p class="section-subtitle">熊本県内で活動する団体をご紹介します</p>
    </div>

    <!-- カテゴリフィルター -->
    <div class="flex flex-wrap gap-2 mb-8" id="filter-btns">
      {categories.map((cat) => (
        <button
          data-category={cat}
          class:list={[
            'px-4 py-2 rounded-full text-sm font-medium border transition-colors filter-btn',
            cat === 'すべて'
              ? 'bg-gray-900 text-white border-gray-900'
              : 'bg-white text-gray-600 border-gray-300 hover:border-gray-500',
          ]}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- 団体カード一覧 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="org-list">
      {orgs.map((org) => (
        <div class="card overflow-hidden org-card" data-category={(org.category ?? []).join(',')}>
          <!-- 写真（16:9） -->
          <div class="relative w-full aspect-video bg-gray-100 overflow-hidden">
            <img
              src={org.photo ? org.photo.url + '?w=640&h=360&fit=crop' : `/placeholders/${org.id}.jpg`}
              alt={org.name}
              width="640"
              height="360"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <!-- カード本文 -->
          <div class="p-6">
            <div class="flex flex-wrap items-center gap-2 mb-3">
              {(org.category ?? []).map((cat) => (
                <span class:list={['badge', categoryColors[cat] ?? 'bg-gray-100 text-gray-600']}>
                  {cat}
                </span>
              ))}
              <span class="text-xs text-gray-400">{org.area}</span>
            </div>
            <h2 class="font-bold text-gray-900 text-lg mb-2">{org.name}</h2>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">{org.description}</p>
            {org.url && (
              <a
                href={org.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-primary-600 font-medium hover:underline inline-flex items-center gap-1"
              >
                Webサイトを見る
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.org-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.category ?? 'すべて';

      // ボタンのスタイル切り替え
      filterBtns.forEach((b) => {
        b.classList.remove('bg-gray-900', 'text-white', 'border-gray-900');
        b.classList.add('bg-white', 'text-gray-600', 'border-gray-300');
      });
      btn.classList.add('bg-gray-900', 'text-white', 'border-gray-900');
      btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-300');

      // カード表示切り替え
      cards.forEach((card) => {
        const cardCategories = (card.dataset.category ?? '').split(',');
        if (selected === 'すべて' || cardCategories.includes(selected)) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
