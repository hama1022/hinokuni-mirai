---
import Layout from '../layouts/Layout.astro';

// FormspreeのフォームID（後で設定）
const FORMSPREE_ID = import.meta.env.FORMSPREE_ID ?? 'YOUR_FORM_ID';
---

<Layout title="お問い合わせ" description="ひのくに未来へのお問い合わせ・掲載依頼">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <h1 class="section-title">お問い合わせ</h1>
      <p class="section-subtitle">掲載依頼・ご質問・情報提供など、お気軽にどうぞ</p>
    </div>

    <!-- お問い合わせ種別 -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      {[
        { icon: '🏢', label: '団体掲載依頼', desc: '団体リストへの掲載を希望される方' },
        { icon: '💰', label: '補助金情報の提供', desc: '補助金・助成金情報を教えていただける方' },
        { icon: '💬', label: 'その他のご質問', desc: 'サイトに関するお問い合わせ全般' },
      ].map((item) => (
        <div class="text-center bg-gray-50 rounded-xl p-4">
          <div class="text-2xl mb-2">{item.icon}</div>
          <div class="font-medium text-gray-900 text-sm mb-1">{item.label}</div>
          <div class="text-xs text-gray-500">{item.desc}</div>
        </div>
      ))}
    </div>

    <!-- フォーム -->
    <div class="card p-8">
      <form
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
        id="contact-form"
        class="space-y-6"
      >
        <div>
          <label for="type" class="block text-sm font-medium text-gray-700 mb-1">
            お問い合わせ種別 <span class="text-red-500">*</span>
          </label>
          <select
            id="type"
            name="type"
            required
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
          >
            <option value="">選択してください</option>
            <option value="団体掲載依頼">団体掲載依頼</option>
            <option value="補助金情報の提供">補助金情報の提供</option>
            <option value="その他">その他のご質問</option>
          </select>
        </div>

        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
            お名前（または団体名）<span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="例：山田 太郎 / 熊本〇〇の会"
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            メールアドレス <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="example@example.com"
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
            お問い合わせ内容 <span class="text-red-500">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="6"
            placeholder="お問い合わせ内容をご記入ください"
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent resize-none"
          ></textarea>
        </div>

        <button type="submit" class="btn-primary w-full py-3">
          送信する
        </button>

        <p class="text-xs text-gray-400 text-center">
          送信後、確認メールをお送りします。通常2〜3営業日以内にご返信いたします。
        </p>
      </form>

      <!-- 送信成功メッセージ -->
      <div id="success-msg" class="hidden text-center py-8">
        <div class="text-4xl mb-4">✅</div>
        <h2 class="text-lg font-bold text-gray-900 mb-2">送信が完了しました</h2>
        <p class="text-gray-500 text-sm">お問い合わせいただきありがとうございます。<br />2〜3営業日以内にご連絡いたします。</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('success-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const res = await fetch(form.action, {
      method: 'POST',
      body: data,
      headers: { Accept: 'application/json' },
    });
    if (res.ok) {
      form.classList.add('hidden');
      successMsg?.classList.remove('hidden');
    } else {
      alert('送信に失敗しました。しばらく経ってから再度お試しください。');
    }
  });
</script>
