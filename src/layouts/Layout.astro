---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonicalUrl?: string;
  noIndex?: boolean;
  publishedAt?: string;
  updatedAt?: string;
}

const {
  title,
  description = '火の国未来創造ネット - 熊本の地域団体・NPOを支援するポータルサイト',
  ogImage,
  ogType = 'website',
  canonicalUrl,
  noIndex = false,
  publishedAt,
  updatedAt,
} = Astro.props;

const siteUrl = 'https://hinokunimirai.com';
const siteName = '火の国未来創造ネット';

// canonical: 明示指定があればそれを、なければ現在URLを正規化
const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname.replace(/\/$/, '') || '/'}`;

// OGP画像: 明示指定 → 専用OGP画像
const ogImageUrl = ogImage ?? `${siteUrl}/ogp.png`;

// ページタイトル: トップは詳細なタイトル、他は「ページ名 | サイト名」
const isTop = title === 'トップ';
const pageTitle = isTop
  ? `${siteName}｜熊本県の地域づくり・NPO・ボランティア支援ポータル`
  : `${title} | ${siteName}`;

// WebSite JSON-LD（全ページ共通）
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  alternateName: '火の国未来創造ネット',
  url: siteUrl,
  description: '熊本県内の地域づくり・NPO・地域団体・ボランティア活動を支援するポータルサイト',
  inLanguage: 'ja',
  keywords: '熊本県,地域づくり,NPO,地域団体,ボランティア,まちづくり,補助金,助成金,火の国未来創造ネット',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/organizations?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- 基本SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- OGP (Open Graph Protocol) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ja_JP" />
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {updatedAt && <meta property="article:modified_time" content={updatedAt} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- ファビコン -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- フォント -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- JSON-LD: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

    <!-- JSON-LD: Organization (サイト運営者情報) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: siteName,
      url: siteUrl,
      logo: `${siteUrl}/favicon-512x512.png`,
      description: '熊本県内の地域団体・NPO・ボランティア活動を支援するポータルサイト',
      areaServed: '熊本県',
    })} />

    <!-- ページ固有の追加head要素（JSON-LD等） -->
    <slot name="head" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YJVSWVQ6NG"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YJVSWVQ6NG');
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
